{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PORT SCANNER - created by @g-baskin",
  "version": "0.1.0",
  "identifier": "app.portscanner",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PORT SCANNER - created by @g-baskin",
        "width": 960,
        "height": 760,
        "resizable": true,
        "minWidth": 760,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
